{
  "name": "@adjustcom/adjust-web-sdk",
  "version": "5.8.3",
  "description": "This is the guide to the Javascript SDK of Adjust™ for web sites or web apps. You can read more about Adjust™ at [adjust.com].",
  "scripts": {
    "build:demo": "webpack --mode production --config webpack.demo.config.js",
    "build:sdk": "webpack --config webpack.sdk.config.js",
    "build:snippet": "terser -d env.INTEGRITY=0 -d env.VERSION=\"'latest'\" ./src/snippet.js -o ./dist/sdk.snippet.min.js -c -m",
    "build:snippet-sri": "INTEGRITY=\"sha384-$(openssl dgst -sha384 -binary ./dist/adjust-latest.min.js | openssl base64 -A)\" && terser -d env.VERSION=\"'$npm_package_version'\" -d env.INTEGRITY=\"'$INTEGRITY'\" ./src/snippet.js -o ./dist/sdk.snippet-sri.min.js -c -m && printf '%s' \"$INTEGRITY\" > dist/INTEGRITY",
    "build": "npm-run-all build:sdk build:demo build:snippet build:snippet-sri",
    "build:ci": "npm-run-all build:sdk build:ci:artifacts",
    "build:ci:artifacts": "rm -rf ./dist/artifacts && mkdir -p ./dist/artifacts && cp ./dist/adjust-latest.js ./dist/artifacts/adjust-latest.js && cp ./dist/adjust-latest.min.js ./dist/artifacts/adjust-latest.min.js && cp ./dist/adjust-latest.js \"./dist/artifacts/adjust-$npm_package_version.js\" && cp ./dist/adjust-latest.min.js \"./dist/artifacts/adjust-$npm_package_version.min.js\"",
    "clean": "rm -rf ./demo/*",
    "start": "webpack serve --hot --mode development --config webpack.demo.config.js",
    "lint": "eslint ./src --ext .js,.ts",
    "lint:fix": "npm run lint -- --fix",
    "test": "TZ=UTC jest",
    "test:coverage": "TZ=UTC jest --coverage",
    "test:ci": "TZ=UTC jest",
    "test:all": "npm-run-all test:ci lint types:validate",
    "types:validate": "flow status --quiet && tsc",
    "publish:sync-repos": "git fetch --all && git push public origin/master:refs/heads/v$npm_package_version"
  },
  "main": "dist/adjust-latest.js",
  "types": "dist/adjust-latest.d.ts",
  "keywords": [],
  "author": "Adjust GmbH",
  "license": "MIT",
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/plugin-transform-flow-comments": "^7.29.7",
    "@babel/plugin-transform-modules-commonjs": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-flow": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/compat": "^2.1.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "babel-jest": "^30.4.1",
    "babel-loader": "^10.1.1",
    "core-js": "^3.49.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-webpack-plugin": "^6.0.0",
    "fake-indexeddb": "^6.2.5",
    "flow-bin": "^0.306.0",
    "flowtype-webpack-plugin": "^0.0.3",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-extended": "^7.0.0",
    "jest-localstorage-mock": "^2.4.26",
    "mini-css-extract-plugin": "^2.10.2",
    "npm-run-all": "^4.1.5",
    "regenerator-runtime": "^0.14.1",
    "sass": "^1.100.0",
    "sass-loader": "^16.0.8",
    "template-ejs-loader": "^0.9.4",
    "terser": "^5.48.0",
    "terser-webpack-plugin": "^5.6.1",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.4"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7"
  },
  "files": [
    "dist/adjust-latest.d.ts",
    "dist/adjust-latest.js",
    "dist/adjust-latest.min.js",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adjust/web_sdk.git"
  },
  "bugs": {
    "url": "https://github.com/adjust/web_sdk/issues"
  },
  "homepage": "https://github.com/adjust/web_sdk#readme"
}
